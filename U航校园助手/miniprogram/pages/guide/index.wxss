.guide-hero {
  padding: 32rpx;
  background: #ffffff;
}

.guide-hero .muted {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.55;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
}

.section-extra {
  color: #8a94a6;
  font-size: 22rpx;
  font-weight: 400;
}

.subsection-title {
  margin: 18rpx 4rpx 12rpx;
  color: #4a5568;
  font-size: 25rpx;
  font-weight: 700;
}

.guide-list,
.notice-list,
.service-list {
  overflow: hidden;
}

.guide-item,
.notice-item,
.service-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 120rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #edf0f4;
}

.guide-item:last-child,
.notice-item:last-child,
.service-item:last-child {
  border-bottom: 0;
}

.guide-main,
.notice-main,
.service-main {
  min-width: 0;
}

.guide-title,
.notice-title,
.service-title {
  color: #17202f;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
}

.guide-desc,
.notice-meta,
.service-desc,
.service-meta {
  margin-top: 8rpx;
  color: #697386;
  font-size: 24rpx;
  line-height: 1.45;
}

.service-meta {
  color: #8a6d2f;
}

.guide-action,
.like-button {
  flex: 0 0 auto;
  color: #1f7a5b;
  font-size: 24rpx;
  font-weight: 700;
}

.like-button {
  min-width: 96rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid #d6e7df;
  border-radius: 8rpx;
  text-align: center;
}

.service-panel {
  padding: 24rpx;
}

.service-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.service-tab {
  height: 72rpx;
  border: 1rpx solid #dfe5ec;
  border-radius: 8rpx;
  color: #4a5568;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
  background: #ffffff;
}

.service-tab.active {
  border-color: #1f7a5b;
  color: #ffffff;
  background: #1f7a5b;
}

.service-form {
  margin-top: 22rpx;
}

.service-input,
.service-textarea {
  box-sizing: border-box;
  width: 100%;
  margin-top: 16rpx;
  border: 1rpx solid #dfe5ec;
  border-radius: 8rpx;
  color: #17202f;
  font-size: 26rpx;
  background: #f9fafb;
}

.service-input {
  height: 84rpx;
  min-height: 84rpx;
  padding: 0 20rpx;
  line-height: 84rpx;
}

.service-textarea {
  height: 168rpx;
  min-height: 168rpx;
  padding: 20rpx;
  line-height: 38rpx;
}

.service-submit {
  height: 84rpx;
  margin-top: 18rpx;
  border-radius: 8rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 84rpx;
  background: #1f7a5b;
}

.empty {
  padding: 28rpx;
}

.empty-title {
  color: #17202f;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 10rpx;
  color: #697386;
  font-size: 24rpx;
  line-height: 1.5;
}
