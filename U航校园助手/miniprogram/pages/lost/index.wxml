<view class="page">
  <view class="lost-head panel">
    <view>
      <view class="title">失物招领</view>
      <view class="muted small">优先写清地点、时间、特征，找回后记得标记完成。</view>
    </view>
    <button class="publish-btn" bindtap="goPublish">发布</button>
  </view>

  <view class="switch-row panel">
    <view
      wx:for="{{types}}"
      wx:key="key"
      class="switch-item {{activeType === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="selectType"
    >
      {{item.name}}
    </view>
  </view>

  <view class="chip-row category-row">
    <view
      wx:for="{{categories}}"
      wx:key="key"
      class="chip {{activeCategory === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="selectCategory"
    >
      {{item.name}}
    </view>
  </view>

  <view wx:if="{{posts.length}}">
    <post-card
      wx:for="{{posts}}"
      wx:key="_id"
      post="{{item}}"
      compact="{{true}}"
      bind:open="openDetail"
    />
  </view>

  <view wx:elif="{{!loading}}" class="empty">
    暂时没有相关信息。
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>
