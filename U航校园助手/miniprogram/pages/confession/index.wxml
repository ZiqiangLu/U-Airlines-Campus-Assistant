<view class="page">
  <view class="confession-head panel">
    <view>
      <view class="title">表白墙</view>
      <view class="muted small">表白、祝福、感谢单独展示，所有内容先审后发。</view>
    </view>
    <button class="publish-btn" bindtap="goPublish">发布</button>
  </view>

  <view wx:if="{{posts.length}}" class="list">
    <post-card
      wx:for="{{posts}}"
      wx:key="_id"
      post="{{item}}"
      compact="{{true}}"
      bind:open="openDetail"
    />
  </view>

  <view wx:elif="{{!loading}}" class="empty">还没有表白内容。</view>
  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>
