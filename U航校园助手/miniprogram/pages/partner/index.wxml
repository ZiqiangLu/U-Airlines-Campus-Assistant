<view class="page">
  <view class="partner-head panel">
    <view>
      <view class="title">缘分抽签</view>
      <view class="muted small">当前入口已改为缘分抽签和主题同行。</view>
    </view>
    <button class="publish-btn" bindtap="goPublish">发布</button>
  </view>

  <view class="chip-row category-row">
    <view
      wx:for="{{categories}}"
      wx:key="key"
      class="chip {{activeCategory === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="selectCategory"
    >
      {{item.name}}
    </view>
  </view>

  <view wx:if="{{posts.length}}">
    <post-card
      wx:for="{{posts}}"
      wx:key="_id"
      post="{{item}}"
      compact="{{true}}"
      bind:open="openDetail"
    />
  </view>

  <view wx:elif="{{!loading}}" class="empty">暂时没有缘分抽签信息。</view>
  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>
