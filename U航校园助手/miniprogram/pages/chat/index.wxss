.bottle-page {
  padding-bottom: 48rpx;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fff7f4 54%, #f1fbf6 100%);
}

.hero-sub {
  margin-top: 12rpx;
  color: #5d6878;
  font-size: 26rpx;
  line-height: 1.5;
}

.gender-btn,
.draw-btn {
  flex: 0 0 auto;
  min-width: 132rpx;
  min-height: 76rpx;
  color: #ffffff;
  background: #1f7a5b;
}

.draw-card,
.throw-form {
  margin-top: 22rpx;
  padding: 26rpx;
}

.draw-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.block-title {
  color: #17202f;
  font-size: 30rpx;
  font-weight: 700;
}

.bottle-result,
.bottle-card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.bottle-card {
  margin-bottom: 20rpx;
}

.bottle-meta,
.bottle-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  color: #697386;
  font-size: 23rpx;
}

.bottle-title {
  margin-top: 14rpx;
  color: #17202f;
  font-size: 30rpx;
  font-weight: 700;
}

.bottle-content {
  margin-top: 12rpx;
  color: #30394a;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

.bottle-tools {
  justify-content: space-between;
  margin-top: 18rpx;
}

.form-label {
  margin: 24rpx 0 12rpx;
  color: #17202f;
  font-size: 27rpx;
  font-weight: 700;
}

.form-label:first-child {
  margin-top: 0;
}

.target-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.target-item {
  min-height: 72rpx;
  padding: 16rpx 8rpx;
  border: 1rpx solid #dce2ea;
  border-radius: 8px;
  color: #3f4858;
  background: #ffffff;
  font-size: 24rpx;
  text-align: center;
}

.target-item.active {
  border-color: #1f7a5b;
  color: #ffffff;
  background: #1f7a5b;
}

.bottle-textarea {
  margin-top: 18rpx;
}

.throw-btn {
  margin-top: 22rpx;
}

.filter-row {
  margin-bottom: 18rpx;
}

.loading {
  padding: 28rpx 0;
  color: #697386;
  font-size: 24rpx;
  text-align: center;
}
