.post-card {
  padding: 26rpx;
  margin-bottom: 20rpx;
}

.post-head,
.post-author,
.post-footer,
.counts {
  display: flex;
  align-items: center;
}

.post-head,
.post-footer {
  justify-content: space-between;
  gap: 18rpx;
}

.post-author {
  min-width: 0;
  gap: 18rpx;
}

.avatar {
  flex: 0 0 auto;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #32445f;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 68rpx;
  text-align: center;
}

.author-name {
  max-width: 430rpx;
  overflow: hidden;
  color: #17202f;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  margin-top: 6rpx;
  color: #697386;
  font-size: 23rpx;
}

.status {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-wrap {
  display: flex;
  flex: 0 0 auto;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
  max-width: 220rpx;
}

.status-pin {
  color: #ffffff;
  background: #32445f;
}

.status-feature {
  color: #8a5a08;
  background: #fff3cf;
}

.status-pending {
  color: #8a5a08;
  background: #fff3cf;
}

.status-done {
  color: #1f7a5b;
  background: #e8f5ef;
}

.post-title {
  margin-top: 20rpx;
  color: #17202f;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.post-content {
  margin-top: 16rpx;
  color: #30394a;
  font-size: 29rpx;
  line-height: 1.65;
  word-break: break-word;
}

.post-price {
  margin-top: 12rpx;
  color: #a04612;
  font-size: 32rpx;
  font-weight: 700;
}

.line-clamp {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 20rpx;
}

.post-image {
  width: 100%;
  height: 150rpx;
  border-radius: 6px;
  background: #eef1f5;
}

.post-footer {
  margin-top: 22rpx;
  color: #697386;
  font-size: 24rpx;
}

.location {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.counts {
  flex: 0 0 auto;
  gap: 22rpx;
}
